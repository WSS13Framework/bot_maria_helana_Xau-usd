# Conta: https://app.metaapi.cloud/
METAAPI_TOKEN=seu_token_aqui
METAAPI_ACCOUNT_ID=seu_account_id_aqui
# Benzinga Pro API: https://pro.benzinga.com/pricing/
BENZINGA_API_KEY=sua_key_aqui
BENZINGA_USERNAME=seu_username_aqui

# A — Trading Economics (calendário macro: CPI/NFP/FOMC, actual vs forecast)
# https://tradingeconomics.com/api/pricing.aspx | https://tradingeconomics.com/api/calendar.aspx
# O script envia c=CLIENT:SECRET na query (formato oficial REST), não Basic Auth.
# Recomendado — uma linha como no pacote Python oficial (te.login('client:secret')):
# TRADINGECONOMICS_API_KEY=
# Ou em duas variáveis:
TRADINGECONOMICS_CLIENT=
TRADINGECONOMICS_SECRET=

# B — Twelve Data Pro (DXY/VIX/rates; teste: test_twelvedata_quote.py)
# https://twelvedata.com/prime | https://twelvedata.com/pricing-business
# Chave: https://twelvedata.com/account/api-keys (sem BOM nem aspas no valor)
TWELVEDATA_API_KEY=
# TWELVEDATA_KEY=   # alias opcional se TWELVEDATA_API_KEY estiver vazio

# Opcional — teste executor_direto.py (Binance Futures)
BINANCE_API_KEY=
BINANCE_SECRET_KEY=
